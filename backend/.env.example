# LLM Provider: ollama (local, free) | groq (cloud, free) | gemini | anthropic
LLM_PROVIDER=ollama

# Ollama — local, no API key needed, no rate limits
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434

# Groq — cloud, free tier (console.groq.com), generous limits, fast
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# Gemini — free tier has strict rate limits
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# Anthropic
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# LangSmith observability (smith.langchain.com, free tier)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=finsight

# App
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000
